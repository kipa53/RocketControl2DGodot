[sub_resource type="GDScript" id="GDScript_sh265"]
script/source = "extends RigidBody3D

## how much vertical force to apply when moving.
@export_range(750.0, 3000.0) var Thrust: float = 1000.0
 
## how much torgue force you want to apply
@export_range(10,300) var Torgue: float = 100.0


var is_transitioning: bool = false

@onready var success_sound: AudioStreamPlayer = $SuccessSound
@onready var rocket_audio: AudioStreamPlayer3D = $RocketAudio

@onready var explosion_audio: AudioStreamPlayer = $ExplosionAudio

# Called when the node enters the scene tree for the first time.
func _ready() -> void:
	pass
	


# Called every frame. 'delta' is the elapsed time since the previous frame.
func _process(delta: float) -> void:
	if Input.is_action_pressed(\"boost\"):
		if rocket_audio.playing == false:
			rocket_audio.play()
		apply_central_force(basis.y * delta * Thrust)
	else:rocket_audio.stop()
			
	if Input.is_action_pressed(\"rotate_left\"):
		apply_torque(Vector3(0.0,0.0,Torgue * delta))
	if Input.is_action_pressed(\"rotate_right\"):
		apply_torque(Vector3(0.0,0.0,-Torgue * delta))
		
	

func _on_body_entered(body: Node) -> void:
	if is_transitioning == false:
		if \"goal\" in body.get_groups():
			complete_level(body.file_path)
		if \"floor\" in body.get_groups():
			crash_sequence()
func crash_sequence() -> void:
	print(\"KABOOM!\")
	explosion_audio.play()
	is_transitioning = true
	set_process(false)
	var tween = create_tween()
	tween.tween_interval(1.0)
	tween.tween_callback(get_tree().reload_current_scene)
	
	
func complete_level(next_level_file: String) -> void:
	print(\"Level complete\")
	success_sound.play()
	var tween = create_tween()
	set_process(false)
	is_transitioning = true
	tween.tween_interval(0.5)
	tween.tween_callback(get_tree().change_scene_to_file.bind(next_level_file))
	
"

